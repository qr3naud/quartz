{
  "manifest_version": 3,
  "name": "Quartz",
  "version": "7.85.0",
  "description": "Scope, price, and export Clay enrichment workflows",
  "key": "",
  "permissions": ["activeTab", "cookies", "nativeMessaging", "storage"],
  "host_permissions": [
    "https://api.clay.com/*",
    "https://app.clay.com/*",
    "https://*.s3.us-east-1.amazonaws.com/*",
    "https://*.supabase.co/*",
    "https://docs.google.com/*",
    "http://localhost/*",
    "http://localhost:*/*",
    "http://127.0.0.1/*",
    "http://127.0.0.1:*/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quartz",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/internal-bg.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.clay.com/*"],
      "js": [
        "vendor/supabase-realtime.js",
        "src/supabase.js",
        "src/config.js",
        "src/store.js",
        "src/cost-model.js",
        "src/auth.js",
        "src/user.js",
        "src/workbook-info.js",
        "src/realtime.js",
        "src/api.js",
        "src/pricing.js",
        "src/canvas/svg.js",
        "src/canvas/geometry.js",
        "src/canvas/graph-queries.js",
        "src/canvas/groups.js",
        "src/canvas/credits.js",
        "src/canvas/snap.js",
        "src/canvas/connections.js",
        "src/canvas/connect-flow.js",
        "src/canvas/ui.js",
        "src/canvas/cards.js",
        "src/canvas/persistence.js",
        "src/canvas/index.js",
        "src/canvas/collaborators.js",
        "src/canvas/cursors.js",
        "src/canvas/live-actions.js",
        "src/tabs.js",
        "src/picker.js",
        "src/table-import.js",
        "src/stamps.js",
        "src/highlights.js",
        "src/session-cutoff.js",
        "src/pricing-comparison.js",
        "vendor/jszip.min.js",
        "vendor/exceljs.min.js",
        "src/xlsx-export.js",
        "src/export.js",
        "src/share.js",
        "src/deal-desk.js",
        "src/request-poc.js",
        "src/scope-ads.js",
        "src/admin-settings.js",
        "src/captain-map.js",
        "src/design-explorer.js",
        "src/poc-import.js",
        "src/dust-poc.js",
        "src/sfdc.js",
        "src/account-agent.js",
        "src/pricing-view.js",
        "src/table-view.js",
        "src/pricing-bands.js",
        "src/update-modal.js",
        "src/overlay.js",
        "src/home.js",
        "src/table-focus.js",
        "src/spotlight.js",
        "vendor/canvas-confetti.min.js",
        "src/confetti.js",
        "src/toolbar.js"
      ],
      "css": [
        "styles/tokens.css",
        "styles/primitives.css",
        "styles/button.css",
        "styles/picker.css",
        "styles/overlay.css",
        "styles/canvas.css",
        "styles/cards.css",
        "styles/groups.css",
        "styles/pickers.css",
        "styles/collaborators.css",
        "styles/cursors.css",
        "styles/export.css",
        "styles/share.css",
        "styles/scope-ads.css",
        "styles/dust-poc.css",
        "styles/sfdc.css",
        "styles/account-agent.css",
        "styles/table-view.css",
        "styles/update.css",
        "styles/design-explorer.css",
        "styles/spotlight.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/key-icon.png", "icons/clay-heart.png", "styles/tokens.css"],
      "matches": ["https://app.clay.com/*"]
    }
  ]
}
