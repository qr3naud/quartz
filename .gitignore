# Internal-only docs (architecture, business context, maintainer notes) — kept
# on disk, never pushed to GitHub. AGENTS.md lives at docs/AGENTS.md; the root
# entry below catches any accidental re-creation at the repo root.
docs/
AGENTS.md

# Personal Cursor rules/config — kept on disk for agents, never pushed to GitHub
.cursor/

# Local build output, if any. Per-machine; never tracked alongside source.
dist/

# Chrome auto-generates this binary DNR ruleset cache when the unpacked
# extension is loaded. Per-machine, per-install — never check it in.
_metadata/

# Entire Supabase project (Edge Function source, migrations, seed data,
# config.toml) is internal-only — kept on disk for deploys, never pushed to
# the public repo.
supabase/

# SFDC connection tester + credentials — internal-only, never pushed.
scripts/sfdc/

# Slack secrets setter — reads SLACK_BOT_TOKEN / SLACK_SIGNING_SECRET from env;
# kept on disk for maintainer use, never pushed (see docs/AGENTS.md).
scripts/set-quartz-slack-secrets.sh

# Private RSA key that pins the extension ID via manifest "key". Only the
# public half lives in manifest.json; this private half stays off GitHub.
scripts/updater/quartz-key.pem

# Python bytecode cache from running/compiling the updater host locally.
__pycache__/
*.pyc

# Local secrets (ANTHROPIC_API_KEY, etc.) — per-machine, never pushed.
.env

# Playwright MCP output (screenshots, traces). Pinned here via --output-dir in
# ~/.cursor/mcp.json so shots land in the repo instead of an ephemeral temp dir;
# per-machine scratch, never tracked. Safe to `rm -rf .playwright-mcp/*`.
.playwright-mcp/
